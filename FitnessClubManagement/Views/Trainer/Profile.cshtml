@model FitnessClubManagement.Models.User
@{
    ViewData["Title"] = "Operative Dossier";
    var controllerName = Model.Role == "Trainer" ? "Trainer" : "User";
}

<div class="container py-5 mt-4">
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-uppercase m-0" style="font-size: 2.5rem; letter-spacing: -1px;">OPERATIVE DOSSIER</h2>
            <p class="text-gray mb-0">Manage your personal identification and physical parameters.</p>
        </div>
        <span class="status-badge active border-secondary text-white">SYSTEM ID: #@Model.Id</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-0 border-0 mb-4" style="background-color: rgba(40, 167, 69, 0.1); border-left: 4px solid #28a745 !important; color: #28a745;">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="row g-5">

        <div class="col-lg-5">
            <div class="combat-card p-0 overflow-hidden" style="border-top: 4px solid @(Model.Role == "Trainer" ? "#c084fc" : "var(--accent-red)");">
                <div class="p-4" style="background-color: var(--surface-dark); border-bottom: 1px solid var(--border-color);">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <div style="width: 60px; height: 60px; background-color: var(--bg-dark); border: 2px solid var(--border-color); display: flex; align-items: center; justify-content: center;">
                            <span class="text-gray fw-bold" style="font-size: 1.5rem;">@(Model.Username.Substring(0, 1).ToUpper())</span>
                        </div>
                        <div>
                            <h3 class="fw-bold text-white text-uppercase m-0">@Model.Username</h3>
                            <span class="text-gray small fw-bold text-uppercase" style="letter-spacing: 1px;">@(Model.Role == "Trainer" ? "ELITE TRAINER" : "REGISTERED FIGHTER")</span>
                        </div>
                    </div>
                </div>

                <div class="p-4">
                    <ul class="list-unstyled text-gray small mb-0 d-flex flex-column gap-3">
                        <li><strong class="text-white d-block mb-1">OFFICIAL COMMS:</strong> @Model.Email</li>
                        <li><strong class="text-white d-block mb-1">CLEARANCE LEVEL:</strong> Tier @(Model.Role == "Trainer" ? "2 (Trainer)" : "1 (Standard)")</li>
                        <li><strong class="text-white d-block mb-1">REGISTERED WEIGHT:</strong> @(Model.WeightKgs?.ToString("0.0") ?? "DATA MISSING") KG</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="combat-card p-4">
                <h4 class="fw-bold text-uppercase mb-4">UPDATE PROTOCOL</h4>

                <form asp-controller="@controllerName" asp-action="UpdateProfile" method="post">

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="text-gray small fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">DESIGNATION (NAME)</label>
                            <input type="text" name="username" value="@Model.Username" class="form-control" style="border-radius: 0; padding: 1rem; background-color: var(--bg-dark); border-color: var(--border-color);" required />
                        </div>
                        <div class="col-md-6 mt-4 mt-md-0">
                            <label class="text-gray small fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">BODY MASS (KG)</label>
                            <input type="number" step="0.1" name="weightKgs" value="@Model.WeightKgs" class="form-control" placeholder="e.g. 77.5" style="border-radius: 0; padding: 1rem; background-color: var(--bg-dark); border-color: var(--border-color);" />
                        </div>
                    </div>

                    <div class="mb-5">
                        <label class="text-gray small fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">COMMS CHANNEL (EMAIL)</label>
                        <input type="email" name="email" value="@Model.Email" class="form-control" style="border-radius: 0; padding: 1rem; background-color: var(--bg-dark); border-color: var(--border-color);" required />
                    </div>

                    <button type="submit" class="btn-combat w-100" style="padding: 1rem;">SAVE PARAMETERS</button>
                </form>
            </div>
        </div>

    </div>
</div>