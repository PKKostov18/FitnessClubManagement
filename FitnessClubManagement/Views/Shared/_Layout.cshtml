<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus Combat</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-md">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    NEXUS<span>COMBAT</span>
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                    <ul class="navbar-nav mx-auto gap-4">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Schedule">Schedule</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Sparring</a></li>
                    </ul>

                    <div class="nav-auth d-flex align-items-center gap-3 mt-3 mt-md-0">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-controller="Admin" asp-action="Index" class="nav-link text-warning fw-bold">SYS ADMIN</a>
                            }
                            else if (User.IsInRole("Trainer"))
                            {
                                <a asp-controller="Trainer" asp-action="Index" class="nav-link text-danger fw-bold text-nowrap">TRAINER HQ</a>
                            }
                            else
                            {
                                <a asp-controller="User" asp-action="Dashboard" class="nav-link text-white fw-bold text-nowrap">MY ROSTER</a>
                            }

                            <a asp-controller="Account" asp-action="Logout" class="btn-combat-outline" style="padding: 0.5rem 1.5rem; font-size: 0.8rem;">
                                LOGOUT
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn-combat" style="padding: 0.5rem 1.5rem; font-size: 0.8rem;">
                                LOGIN
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="text-center py-5 mt-5" style="border-top: 1px solid var(--border-color);">
        <div class="container">
            <span style="color: var(--text-muted); font-weight: 800; letter-spacing: 1px;">NEXUS<span style="color: var(--accent-red);">COMBAT</span></span>
            <br />
            <span style="color: var(--border-color); font-size: 0.85rem; font-weight: 600;">EST. 2026 // ELITE TRAINING SYSTEMS</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function () {
        setTimeout(function () {
        var activeAlerts = document.querySelectorAll('.alert');
        activeAlerts.forEach(function (alert) {
        alert.style.transition = "opacity 0.5s ease";
        alert.style.opacity = "0";
        setTimeout(function () {
        alert.remove();
        }, 500);
        });
        }, 2000);
        });
    </script>
</body>
</html>