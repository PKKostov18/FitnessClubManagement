<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Nexus Fit</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Органични течни елементи във фона (Liquid Glass Base) -->
    <div class="liquid-bg">
        <div class="liquid-blob blob-purple"></div>
        <div class="liquid-blob blob-blue"></div>
        <div class="liquid-blob blob-pink"></div>
    </div>

    <header class="fixed-top d-flex justify-content-center pt-4">
        <nav class="navbar navbar-expand-md liquid-nav container">
            <a class="navbar-brand fw-extrabold" asp-controller="Home" asp-action="Index">
                NEXUS<span class="glass-dot">.</span>FIT
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                <ul class="navbar-nav mx-auto gap-4">
                    <li class="nav-item"><a class="nav-link active" asp-controller="Home" asp-action="Index">Dashboard</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Schedule</a></li>
                    <li class="nav-item"><a class="nav-link" href="#">Sparring</a></li>
                </ul>
                <div class="nav-auth">
                    <a href="#" class="btn btn-liquid-pill">Login</a>
                </div>
            </div>
        </nav>
    </header>

    <div class="main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="liquid-footer text-center">
        <div class="container">
            <span class="footer-brand">NEXUS.FIT</span> &copy; 2026 // Liquid Glass Architecture
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>