@model FitnessClubManagement.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="glass-panel" style="width: 100%; max-width: 450px;">
        <h2 class="text-center mb-4 fw-bold">INITIALIZE PROFILE</h2>
        <form asp-action="Register" method="post">
            <div class="mb-3">
                <label class="text-secondary small mb-1">FIGHTER NAME</label>
                <input asp-for="Username" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="text-secondary small mb-1">SECURE EMAIL</label>
                <input asp-for="Email" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label class="text-secondary small mb-1">PASSWORD</label>
                <input asp-for="Password" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label class="text-secondary small mb-1">CONFIRM PASSWORD</label>
                <input asp-for="ConfirmPassword" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-liquid-primary w-100 mb-3">CREATE ACCOUNT</button>
            <div class="text-center">
                <span class="text-secondary small">Already inside the Nexus?</span>
                <a asp-action="Login" class="text-white text-decoration-none fw-bold small">Login here</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}