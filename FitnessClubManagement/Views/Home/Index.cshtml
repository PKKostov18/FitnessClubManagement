@{
    ViewData["Title"] = "Liquid Dashboard";
}

<div class="container text-center mb-5 pb-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <h1 class="hero-title mb-4 text-uppercase">Forge Your<br>Ultimate Self</h1>
            <p class="hero-subtitle mb-5">
                A fluid digital environment running on glass-morphic architecture. Synchronize your combative training, track macros, and master your performance.
            </p>
            <a href="#" class="btn btn-liquid-primary text-uppercase">Initialize Access</a>
        </div>
    </div>
</div>

<div class="container mt-5">
    <div class="row g-4">

        <!-- PANEL 1: SPARRING (Широк изцяло течен премиум панел) -->
        <div class="col-12">
            <div class="glass-panel d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-4">
                <div style="max-width: 750px;">
                    <div class="panel-icon">🥊</div>
                    <h3 class="mb-3">Advanced Sparring Matchmaking</h3>
                    <p>
                        Skip the friction of finding elite training partners. Define your fighting style, accurate weight class, and combat experience. The platform instantly charts compatible athletes inside your club for coordinated, safe, and tactical open sparring.
                    </p>
                </div>
                <div class="text-md-end flex-shrink-0">
                    <span class="glass-tag text-uppercase">Engine Active</span>
                </div>
            </div>
        </div>

        <!-- PANEL 2: NUTRITION -->
        <div class="col-md-6">
            <div class="glass-panel h-100 d-flex flex-column justify-content-between">
                <div>
                    <div class="panel-icon">🥩</div>
                    <h3 class="mb-3">Hydration & Macro System</h3>
                    <p>
                        Automated structural allocation for your nutrient goals. Inputs are calculated directly against your real-time body mass updates to maintain peak physical output.
                    </p>
                </div>
                <div class="mt-4 pt-2">
                    <span class="text-white-50 small">✓ Real-time sync operational</span>
                </div>
            </div>
        </div>

        <!-- PANEL 3: SCHEDULE -->
        <div class="col-md-6">
            <div class="glass-panel h-100 d-flex flex-column justify-content-between">
                <div>
                    <div class="panel-icon">📅</div>
                    <h3 class="mb-3">Intelligent Session Booking</h3>
                    <p>
                        High-velocity queue architecture for combat and conditioning classes. Secure slots for MMA, Boxing, and CrossFit with instant capacity notifications.
                    </p>
                </div>
                <div class="mt-4 pt-2">
                    <span class="text-white-50 small">✓ WebSockets tracking active</span>
                </div>
            </div>
        </div>

    </div>
</div>