@model IEnumerable<FitnessClubManagement.Models.User>
@{
    ViewData["Title"] = "Admin Command Center";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-uppercase m-0">SYSTEM ROSTER</h2>
        <a asp-action="AddTrainer" class="btn btn-liquid-primary">
            + HIRE TRAINER
        </a>
    </div>

    <div class="glass-panel p-0 overflow-hidden">
        <table class="table table-dark table-hover mb-0" style="background: transparent;">
            <thead style="background: rgba(255, 255, 255, 0.05);">
                <tr>
                    <th class="p-4 text-secondary text-uppercase small">ID</th>
                    <th class="p-4 text-secondary text-uppercase small">Name</th>
                    <th class="p-4 text-secondary text-uppercase small">Email</th>
                    <th class="p-4 text-secondary text-uppercase small">Role</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr style="border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
                        <td class="p-4 align-middle text-white-50">#@user.Id</td>
                        <td class="p-4 align-middle fw-bold">@user.Username</td>
                        <td class="p-4 align-middle text-white-50">@user.Email</td>
                        <td class="p-4 align-middle">
                            @if (user.Role == "Admin")
                            {
                                <span class="badge bg-danger rounded-pill px-3 py-2">SYS ADMIN</span>
                            }
                            else if (user.Role == "Trainer")
                            {
                                <span class="badge rounded-pill px-3 py-2" style="background: rgba(168, 85, 247, 0.4); border: 1px solid #a855f7;">TRAINER</span>
                            }
                            else
                            {
                                <span class="badge bg-dark border border-secondary rounded-pill px-3 py-2 text-white-50">FIGHTER</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>