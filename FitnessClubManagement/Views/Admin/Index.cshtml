@model IEnumerable<FitnessClubManagement.Models.User>
@{
    ViewData["Title"] = "System Roster";
}

<div class="container py-5 mt-4">
    <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold text-uppercase m-0" style="font-size: 2.5rem; letter-spacing: -1px;">SYSTEM ROSTER</h2>
            <p class="text-gray mb-0">Manage platform access, assign trainer protocols, and terminate accounts.</p>
        </div>
        <a asp-action="AddTrainer" class="btn-combat" style="padding: 0.6rem 1.5rem; font-size: 0.85rem;">
            + DEPLOY NEW TRAINER
        </a>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="combat-card p-4" style="border-top: 4px solid var(--text-gray);">
                <div class="text-gray small fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">TOTAL FIGHTERS</div>
                <div class="fw-bold text-white" style="font-size: 3rem; line-height: 1; letter-spacing: -2px;">
                    @ViewBag.TotalFighters
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="combat-card p-4" style="border-top: 4px solid #c084fc;">
                <div class="text-gray small fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">ACTIVE TRAINERS</div>
                <div class="fw-bold text-white" style="font-size: 3rem; line-height: 1; letter-spacing: -2px;">
                    @ViewBag.ActiveTrainers
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="combat-card p-4" style="border-top: 4px solid var(--accent-red);">
                <div class="text-gray small fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">DEPLOYED SESSIONS</div>
                <div class="fw-bold text-white" style="font-size: 3rem; line-height: 1; letter-spacing: -2px;">
                    @ViewBag.DeployedSessions
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="combat-card p-4" style="border-top: 4px solid #0dcaf0;">
                <div class="text-gray small fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">GLOBAL ROSTER LOAD</div>
                <div class="fw-bold text-white" style="font-size: 3rem; line-height: 1; letter-spacing: -2px;">
                    @ViewBag.GlobalRosterLoad
                </div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-0 border-0 mb-4" style="background-color: rgba(40, 167, 69, 0.1); border-left: 4px solid #28a745 !important; color: #28a745;">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead>
                <tr>
                    <th class="text-gray">ID</th>
                    <th class="text-gray">FIGHTER NAME</th>
                    <th class="text-gray">EMAIL</th>
                    <th class="text-gray">ROLE</th>
                    <th class="text-gray text-end">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="text-white-50 align-middle">#@user.Id</td>
                        <td class="fw-bold text-white align-middle">@user.Username</td>
                        <td class="text-gray align-middle">@user.Email</td>
                        <td class="align-middle">
                            @if (user.Role == "Admin")
                            {
                                <span class="status-badge active border-danger text-danger">SYS ADMIN</span>
                            }
                            else if (user.Role == "Trainer")
                            {
                                <span class="status-badge" style="color: #c084fc; border-color: rgba(168, 85, 247, 0.4);">TRAINER</span>
                            }
                            else
                            {
                                <span class="status-badge">FIGHTER</span>
                            }
                        </td>
                        <td class="text-end align-middle">
                            @if (user.Role != "Admin")
                            {
                                <div class="d-flex justify-content-end gap-2">
                                    @if (user.Role == "User")
                                    {
                                        <form asp-action="ChangeRole" method="post">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <input type="hidden" name="newRole" value="Trainer" />
                                            <button type="submit" class="btn btn-sm btn-outline-light rounded-0" style="font-size: 0.75rem; font-weight: 700;">HIRE TRAINER</button>
                                        </form>
                                    }
                                    else if (user.Role == "Trainer")
                                    {
                                        <form asp-action="ChangeRole" method="post">
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <input type="hidden" name="newRole" value="User" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary rounded-0" style="font-size: 0.75rem; font-weight: 700;">DEMOTE</button>
                                        </form>
                                    }

                                    <form asp-action="DeleteUser" method="post" onsubmit="return confirm('WARNING: Terminating this account is permanent. Proceed?');">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-0" style="font-size: 0.75rem; font-weight: 700;">TERMINATE</button>
                                    </form>
                                </div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>