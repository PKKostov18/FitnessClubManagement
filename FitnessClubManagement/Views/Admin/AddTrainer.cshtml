@model FitnessClubManagement.ViewModels.AddTrainerViewModel
@{
    ViewData["Title"] = "Deploy Trainer";
}

<div class="container d-flex justify-content-center align-items-center mt-5" style="min-height: 60vh;">
    <div class="combat-card" style="width: 100%; max-width: 550px;">

        <div class="d-flex align-items-center gap-3 mb-4">
            <span class="status-badge active border-danger text-danger">ADMIN CLEARANCE</span>
            <h3 class="m-0 fw-bold text-uppercase" style="letter-spacing: -1px;">AUTHORIZE TRAINER</h3>
        </div>

        <form asp-action="AddTrainer" method="post">
            <div class="mb-4">
                <label class="text-gray small fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">TRAINER DESIGNATION (NAME)</label>
                <input asp-for="Username" class="form-control" style="border-radius: 0; padding: 1rem; background-color: var(--bg-dark); border-color: var(--border-color);" />
                <span asp-validation-for="Username" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label class="text-gray small fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">OFFICIAL EMAIL</label>
                <input asp-for="Email" class="form-control" style="border-radius: 0; padding: 1rem; background-color: var(--bg-dark); border-color: var(--border-color);" />
                <span asp-validation-for="Email" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <div class="mb-5">
                <label class="text-gray small fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">INITIAL ACCESS CODE (PASSWORD)</label>
                <input asp-for="Password" type="password" class="form-control" style="border-radius: 0; padding: 1rem; background-color: var(--bg-dark); border-color: var(--border-color);" />
                <span asp-validation-for="Password" class="text-danger small fw-bold mt-1 d-block"></span>
            </div>

            <div class="d-flex gap-3">
                <a asp-action="Index" class="btn-combat-outline w-50 text-center" style="padding: 1rem;">ABORT</a>
                <button type="submit" class="btn-combat w-50" style="padding: 1rem;">GRANT ACCESS</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}