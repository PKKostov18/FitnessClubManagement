@model FitnessClubManagement.ViewModels.AddTrainerViewModel
@{
    ViewData["Title"] = "Add New Trainer";
}

<div class="container d-flex justify-content-center align-items-center mt-5" style="min-height: 60vh;">
    <div class="glass-panel" style="width: 100%; max-width: 500px;">
        <h3 class="text-center mb-4 fw-bold text-uppercase">AUTHORIZE NEW TRAINER</h3>

        <form asp-action="AddTrainer" method="post">
            <div class="mb-3">
                <label class="text-secondary small mb-1">TRAINER DESIGNATION (NAME)</label>
                <input asp-for="Username" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="Username" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="text-secondary small mb-1">OFFICIAL EMAIL</label>
                <input asp-for="Email" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="text-secondary small mb-1">INITIAL ACCESS CODE (PASSWORD)</label>
                <input asp-for="Password" class="form-control bg-dark text-white border-secondary" style="border-radius: 12px; padding: 12px;" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-3">
                <a asp-action="Index" class="btn btn-outline-secondary w-50" style="border-radius: 100px; padding: 12px;">CANCEL</a>
                <button type="submit" class="btn btn-liquid-primary w-50">GRANT ACCESS</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}